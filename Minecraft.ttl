@prefix : <http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/> .

<http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/attacks
:attacks rdf:type owl:ObjectProperty ,
                  owl:AsymmetricProperty ,
                  owl:IrreflexiveProperty ;
         rdfs:domain :HostileMob ;
         rdfs:range :Player .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/behaves
:behaves rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdf:type owl:FunctionalProperty ;
         rdfs:domain :Mob ;
         rdfs:range :Behavior .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/contributesTo
:contributesTo rdf:type owl:ObjectProperty ,
                        owl:TransitiveProperty ;
               owl:propertyChainAxiom ( [ owl:inverseOf :craftedWith
                                        ]
                                        [ owl:inverseOf :craftedWith
                                        ]
                                      ) .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/craftedWith
:craftedWith rdf:type owl:ObjectProperty ;
             owl:inverseOf :craftsInto ;
             rdfs:domain :Item ;
             rdfs:range :Item .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/craftsInto
:craftsInto rdf:type owl:ObjectProperty ;
            rdfs:domain :Item ;
            rdfs:range :Item .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/dropsItem
:dropsItem rdf:type owl:ObjectProperty ;
           rdfs:domain :Mob ;
           rdfs:range :Item .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/harvestedWith
:harvestedWith rdf:type owl:ObjectProperty ,
                        owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               rdfs:domain :Block ;
               rdfs:range :Tool .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/inDimension
:inDimension rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Biome ;
             rdfs:range :Dimension .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/indirectResourceFor
:indirectResourceFor rdf:type owl:ObjectProperty ;
                     rdfs:domain :Mob ;
                     rdfs:range :Item ;
                     owl:propertyChainAxiom ( :dropsItem
                                              [ owl:inverseOf :craftedWith
                                              ]
                                            ) .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/livesIn
:livesIn rdf:type owl:ObjectProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Player ;
         rdfs:range :OverworldBiome .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/rarity
:rarity rdf:type owl:ObjectProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :Item ;
        rdfs:range :Rarity .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/smeltedFrom
:smeltedFrom rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Item ;
             rdfs:range :Item .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/spawnsIn
:spawnsIn rdf:type owl:ObjectProperty ,
                   owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain :Mob ;
          rdfs:range :Biome .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/tamedBy
:tamedBy rdf:type owl:ObjectProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Tameable ;
         rdfs:range :Player .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/armorPoints
:armorPoints rdf:type owl:DatatypeProperty ;
             rdfs:domain :Wearable ;
             rdfs:range xsd:integer .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/attackSpeed
:attackSpeed rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :Tool ;
             rdfs:range xsd:decimal .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/damage
:damage rdf:type owl:DatatypeProperty ;
        rdfs:domain :Tool ;
        rdfs:range xsd:integer .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/durability
:durability rdf:type owl:DatatypeProperty ;
            rdfs:domain :Item ;
            rdfs:range xsd:integer .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/health
:health rdf:type owl:DatatypeProperty ;
        rdfs:domain [ rdf:type owl:Class ;
                      owl:unionOf ( :Mob
                                    :Player
                                  )
                    ] ;
        rdfs:range xsd:integer .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/stackSize
:stackSize rdf:type owl:DatatypeProperty ;
           rdfs:domain :Item ;
           rdfs:range xsd:integer .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Allay
:Allay rdf:type owl:Class ;
       rdfs:subClassOf :Mob ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :behaves ;
                         owl:someValuesFrom :Passive
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :dropsItem ;
                         owl:qualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                         owl:onClass :Item
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :health ;
                         owl:hasValue "20"^^xsd:nonNegativeInteger
                       ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Animal
:Animal rdf:type owl:Class ;
        rdfs:subClassOf :Mob .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Aquatic
:Aquatic rdf:type owl:Class ;
         rdfs:subClassOf :Mob .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Armadillo
:Armadillo rdf:type owl:Class ;
           rdfs:subClassOf :Animal ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :behaves ;
                             owl:someValuesFrom :Passive
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :spawnsIn ;
                             owl:someValuesFrom [ rdf:type owl:Class ;
                                                  owl:unionOf ( :Badlands
                                                                :ErodedBadlands
                                                                :Savanna
                                                                :SavannaPlateau
                                                                :WoodedBadlands
                                                              )
                                                ]
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :dropsItem ;
                             owl:allValuesFrom :ArmadilloScute
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :spawnsIn ;
                             owl:allValuesFrom [ rdf:type owl:Class ;
                                                 owl:unionOf ( :Badlands
                                                               :ErodedBadlands
                                                               :Savanna
                                                               :SavannaPlateau
                                                               :WoodedBadlands
                                                             )
                                               ]
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :dropsItem ;
                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :ArmadilloScute
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :health ;
                             owl:hasValue "12"^^xsd:nonNegativeInteger
                           ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/ArmadilloScute
:ArmadilloScute rdf:type owl:Class ;
                rdfs:subClassOf :Item ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :rarity ;
                                  owl:someValuesFrom :Common
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :stackSize ;
                                  owl:hasValue "64"^^xsd:nonNegativeInteger
                                ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/ArmorTrim
:ArmorTrim rdf:type owl:Class ;
           rdfs:subClassOf :Item ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :rarity ;
                             owl:someValuesFrom :Common
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :stackSize ;
                             owl:hasValue "64"^^xsd:nonNegativeInteger
                           ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Arrow
:Arrow rdf:type owl:Class ;
       rdfs:subClassOf :Item ,
                       [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                owl:onProperty :craftedWith ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass :Feather
                                              ]
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :craftedWith ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass :Flint
                                              ]
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :craftedWith ;
                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                owl:onClass :Stick
                                              ]
                                            ) ;
                         rdf:type owl:Class
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :rarity ;
                         owl:someValuesFrom :Common
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :stackSize ;
                         owl:hasValue "64"^^xsd:nonNegativeInteger
                       ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/ArrowOfPoison
:ArrowOfPoison rdf:type owl:Class ;
               rdfs:subClassOf :Item ,
                               [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                        owl:onProperty :craftedWith ;
                                                        owl:someValuesFrom :Arrow
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :craftedWith ;
                                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass :LingeringPotionOfPoison
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :rarity ;
                                 owl:allValuesFrom :Common
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :stackSize ;
                                 owl:hasValue "64"^^xsd:nonNegativeInteger
                               ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/ArrowOfSlowness
:ArrowOfSlowness rdf:type owl:Class ;
                 rdfs:subClassOf :Item ,
                                 [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                          owl:onProperty :craftedWith ;
                                                          owl:someValuesFrom :Arrow
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :craftedWith ;
                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass :LingeringPotionOfSlowness
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :rarity ;
                                   owl:allValuesFrom :Common
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :stackSize ;
                                   owl:hasValue "64"^^xsd:nonNegativeInteger
                                 ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/ArrowOfWeakness
:ArrowOfWeakness rdf:type owl:Class ;
                 rdfs:subClassOf :Item ,
                                 [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                          owl:onProperty :craftedWith ;
                                                          owl:someValuesFrom :Arrow
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :craftedWith ;
                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass :LingeringPotionOfWeakness
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :rarity ;
                                   owl:allValuesFrom :Common
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :stackSize ;
                                   owl:hasValue "64"^^xsd:nonNegativeInteger
                                 ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Arthropod
:Arthropod rdf:type owl:Class ;
           rdfs:subClassOf :Mob .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Axe
:Axe rdf:type owl:Class ;
     rdfs:subClassOf :Tool ,
                     :Weapon ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :stackSize ;
                       owl:hasValue "1"^^xsd:nonNegativeInteger
                     ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Axolotl
:Axolotl rdf:type owl:Class ;
         rdfs:subClassOf :Animal ,
                         :Aquatic ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :behaves ;
                           owl:someValuesFrom :Passive
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :spawnsIn ;
                           owl:someValuesFrom :LushCaves
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :spawnsIn ;
                           owl:allValuesFrom :LushCaves
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :dropsItem ;
                           owl:qualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                           owl:onClass :Item
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :health ;
                           owl:hasValue "14"^^xsd:nonNegativeInteger
                         ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Badlands
:Badlands rdf:type owl:Class ;
          rdfs:subClassOf :WarmBiome ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :inDimension ;
                            owl:hasValue :Overworld
                          ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Bamboo
:Bamboo rdf:type owl:Class ;
        rdfs:subClassOf :Item ,
                        :NotFullBlock ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :rarity ;
                          owl:someValuesFrom :Common
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :stackSize ;
                          owl:hasValue "64"^^xsd:nonNegativeInteger
                        ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/BambooJungle
:BambooJungle rdf:type owl:Class ;
              rdfs:subClassOf :WarmBiome ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :inDimension ;
                                owl:hasValue :Overworld
                              ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/BasaltDeltas
:BasaltDeltas rdf:type owl:Class ;
              rdfs:subClassOf :WarmBiome ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :inDimension ;
                                owl:hasValue :Nether
                              ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Bat
:Bat rdf:type owl:Class ;
     rdfs:subClassOf :Animal ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :behaves ;
                       owl:someValuesFrom :Passive
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :spawnsIn ;
                       owl:someValuesFrom :OverworldBiome
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :spawnsIn ;
                       owl:allValuesFrom :OverworldBiome
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :dropsItem ;
                       owl:qualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                       owl:onClass :Item
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :health ;
                       owl:hasValue "6"^^xsd:nonNegativeInteger
                     ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Beach
:Beach rdf:type owl:Class ;
       rdfs:subClassOf :TemperateBiome ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :inDimension ;
                         owl:hasValue :Overworld
                       ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Beacon
:Beacon rdf:type owl:Class ;
        rdfs:subClassOf :Item ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :craftedWith ;
                          owl:someValuesFrom :NetherStar
                        ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Bee
:Bee rdf:type owl:Class ;
     rdfs:subClassOf :Animal ,
                     :Arthropod ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :behaves ;
                       owl:someValuesFrom :Neutral
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :spawnsIn ;
                       owl:someValuesFrom [ rdf:type owl:Class ;
                                            owl:unionOf ( :BirchForest
                                                          :CherryGrove
                                                          :FlowerForest
                                                          :Forest
                                                          :MangroveSwamp
                                                          :Meadow
                                                          :OldGrowthBirchForest
                                                          :Plains
                                                          :SunflowerPlains
                                                        )
                                          ]
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :spawnsIn ;
                       owl:allValuesFrom [ rdf:type owl:Class ;
                                           owl:unionOf ( :BirchForest
                                                         :CherryGrove
                                                         :FlowerForest
                                                         :Forest
                                                         :MangroveSwamp
                                                         :Meadow
                                                         :OldGrowthBirchForest
                                                         :Plains
                                                         :SunflowerPlains
                                                       )
                                         ]
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :dropsItem ;
                       owl:qualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                       owl:onClass :Item
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :health ;
                       owl:hasValue "10"^^xsd:nonNegativeInteger
                     ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Beetroot
:Beetroot rdf:type owl:Class ;
          rdfs:subClassOf :Crops ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :rarity ;
                            owl:someValuesFrom :Common
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :stackSize ;
                            owl:hasValue "64"^^xsd:nonNegativeInteger
                          ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Behavior
:Behavior rdf:type owl:Class .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Biome
:Biome rdf:type owl:Class .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/BirchForest
:BirchForest rdf:type owl:Class ;
             rdfs:subClassOf :TemperateBiome ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :inDimension ;
                               owl:hasValue :Overworld
                             ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/BlackDye
:BlackDye rdf:type owl:Class ;
          rdfs:subClassOf :Dye ,
                          [ rdf:type owl:Class ;
                            owl:unionOf ( [ rdf:type owl:Restriction ;
                                            owl:onProperty :craftedWith ;
                                            owl:someValuesFrom :InkSac
                                          ]
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :craftedWith ;
                                            owl:someValuesFrom :WitherRose
                                          ]
                                        )
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :rarity ;
                            owl:someValuesFrom :Common
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :stackSize ;
                            owl:hasValue "64"^^xsd:nonNegativeInteger
                          ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/BlackWool
:BlackWool rdf:type owl:Class ;
           rdfs:subClassOf :FullBlock ,
                           :Wool ,
                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                    owl:onProperty :craftedWith ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass :BlackDye
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :craftedWith ;
                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                    owl:onClass :Wool
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :harvestedWith ;
                             owl:someValuesFrom :Shears
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :rarity ;
                             owl:someValuesFrom :Common
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :stackSize ;
                             owl:hasValue "64"^^xsd:nonNegativeInteger
                           ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/Blaze
:Blaze rdf:type owl:Class ;
       rdfs:subClassOf :Monster ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :behaves ;
                         owl:someValuesFrom :Hostile
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :spawnsIn ;
                         owl:someValuesFrom :NetherBiome
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :dropsItem ;
                         owl:allValuesFrom :BlazeRod
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :spawnsIn ;
                         owl:allValuesFrom :NetherBiome
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :dropsItem ;
                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :BlazeRod
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :health ;
                         owl:hasValue "20"^^xsd:nonNegativeInteger
                       ] .


###  http://www.semanticweb.org/bboeckle/ontologies/2026/4/Minecraft/BlazePowder
:BlazePowder rdf:type owl:Class ;
             rdfs:subClassOf :Item ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :rarity ;
                               owl:someValuesFrom :Common
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :craftedWith ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass :BlazeRod
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :stackSize ;
