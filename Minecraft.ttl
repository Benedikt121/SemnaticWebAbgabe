#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Axe
                :Hoe
                :Pickaxe
                :Shovel
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Boots
                :Chestplate
                :Helmet
                :Leggings
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Common
                :Epic
                :Rare
                :Uncommon
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Hostile
                :Neutral
                :Passive
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( :Alex
                        :End
                        :Enderdragon
                        :Nether
                        :Overworld
                        :Pluto
                        :Steve
                        :TheEnd
                      )
] .


#################################################################
#    Rules
#################################################################

:m rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:p rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "HostileMobAttackRule" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :HostileMob ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :m
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#classPredicate> :Player ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :p
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :attacks ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :m ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> :p
                                                     ] ;
                                           rdf:rest rdf:nil
